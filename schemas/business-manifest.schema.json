{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://messy-data-bi-harness.local/schemas/business-manifest.schema.json",
  "title": "Business Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "businessId",
    "businessName",
    "category",
    "location",
    "status",
    "rawPacket",
    "sources",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "businessId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "businessName": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["city", "region", "country"],
      "properties": {
        "city": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "country": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["raw-packet-only", "extraction-ready", "archived"]
    },
    "rawPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "format"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "enum": ["markdown"]
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "format"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "enum": ["json"]
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date"
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    }
  }
}
